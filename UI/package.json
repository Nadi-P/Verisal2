{
  "name": "verisal",
  "type": "module",
  "version": "1.0.0",
  "description": "Verisal Data Processing",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.verisal.app",
    "productName": "Verisal",
    "asar": false,
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "icon": "public/verisal-app-icon.ico",
      "target": ["msi"]
    },
    "extraResources": [
      {
        "from": "../Processing/dist/verisal-backend.exe",
        "to": "backend/verisal-backend.exe"
      }
    ]
  }
}