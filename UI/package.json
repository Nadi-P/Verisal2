{
  "name": "verisal",
  "type": "module",
  "version": "1.0.0",
  "description": "Verisal Data Processing",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.verisal.app",
    "productName": "Verisal",
    "asar": false,
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "icon": "public/verisal-app-icon.ico",
      "target": [
        "msi"
      ]
    },
    "extraResources": [
      {
        "from": "../Processing/dist/verisal-backend.exe",
        "to": "backend/verisal-backend.exe"
      }
    ]
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lodash": "^4.17.21",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "^7.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "vite": "^5.0.0"
  }
}
